VITE_SIGNALING_WS_URL=wss://signal.example.com/ws
VITE_ICE_SERVERS=[{"urls":"stun:turn.example.com:3478"},{"urls":"turn:turn.example.com:3478?transport=udp","username":"<turn-user>","credential":"<turn-pass>"},{"urls":"turn:turn.example.com:3478?transport=tcp","username":"<turn-user>","credential":"<turn-pass>"},{"urls":"turns:turn.example.com:5349?transport=tcp","username":"<turn-user>","credential":"<turn-pass>"}]
# Preferred with Cloudflare TURN: backend mints short-lived ICE credentials.
VITE_TURN_CREDENTIALS_URL=https://signal.example.com/turn-credentials
VITE_TURN_CREDENTIALS_TTL_SECONDS=3600
# Optional QA-only flag. Forces relay path (TURN) to validate blocked P2P scenarios.
VITE_FORCE_RELAY=false
